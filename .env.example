# 运行环境（生产环境必须设为 production，否则不强制校验密钥）
NODE_ENV=production

# 服务端口
PORT=3000

# 数据库路径
OA_DB_PATH=./data/oa.sqlite

# JWT 密钥：生产环境必填，长度 >= 16 的随机串（可用 `openssl rand -hex 24` 生成）
OA_JWT_SECRET=please-change-this-to-a-long-random-secret

# 跨域白名单（逗号分隔），内网同源部署可留空
# OA_CORS_ORIGINS=https://oa.ggcdc.local

# 附件白名单与大小（MB）
# OA_UPLOAD_EXTS=.pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.zip
# OA_UPLOAD_MAX_MB=50

# 登录失败锁定：连续失败次数与锁定分钟
# OA_LOGIN_MAX_FAILS=5
# OA_LOGIN_LOCK_MINUTES=15

# 接口限流：时间窗口(ms)与窗口内最大请求数
# OA_RATE_WINDOW_MS=60000
# OA_RATE_MAX=600

# 登录令牌有效期
# OA_TOKEN_TTL=8h

# 备份保留份数
# OA_BACKUP_KEEP=30
